<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base application theme. -->
    <style name="Theme.BharatScan" parent="Theme.AppCompat.Light.NoActionBar">
        <!-- Status bar and navigation bar colors -->
        <item name="android:statusBarColor">@color/deep_navy_blue</item>
        <item name="android:navigationBarColor">@color/deep_navy_blue</item>
        <item name="android:windowBackground">@color/deep_navy_blue</item>
    </style>

    <!-- Splash Screen Theme -->
    <style name="Theme.App.Starting" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/deep_navy_blue</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/logo</item>
        <item name="postSplashScreenTheme">@style/Theme.BharatScan</item>
    </style>
</resources>
